{
  "expo": {
    "name": "Be",
    "slug": "version10app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "version10app",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.bickers.beapp",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bickers.beapp",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-apple-authentication",
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to use your camera for meal scan.",
          "photosPermission": "Allow $(PRODUCT_NAME) to access photos for nutrition logging."
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for voice meal logging.",
          "speechRecognitionPermission": "Allow $(PRODUCT_NAME) to convert your speech into meal logs."
        }
      ],
      "expo-widgets"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "673c38e7-035e-442a-b89b-5763837c0d81"
      }
    },
    "owner": "masonbickers"
  }
}
